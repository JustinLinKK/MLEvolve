MERGE (n:Hardware {hardware_id: "nvidia.blackwell.b200.spec"}) SET n += apoc.convert.fromJsonMap('{"hardware_id": "nvidia.blackwell.b200.spec", "name": "NVIDIA B200", "vendor": "nvidia", "aliases": ["b200"], "architectures": ["blackwell"], "compute_capabilities": ["10.0"], "vram_MB": 196608, "vram_type": "hbm3e", "sm_count": 148, "workload_types": ["vision_training", "transformer_training", "generative_ai", "llm_training", "hpc", "matmul_heavy", "transformer_inference", "vision_inference"], "recommended_patterns": ["keep precision/grad_accum/max_seq_len/optimizer configurable", "use PyTorch SDPA before hard-coded flash-attn dependency [https://docs.pytorch.org/docs/2.12/generated/torch.nn.functional.scaled_dot_product_attention.html]", "activation checkpointing when activation memory dominates [https://docs.pytorch.org/docs/2.12/checkpoint.html]", "sequence packing and KV-cache budget before longer context", "use 180GB HBM3e and 8TB/s bandwidth for single-GPU model/KV sizing [https://docs.nvidia.com/enterprise-reference-architectures/hgx-ai-factory/latest/components.html]", "use NVFP4/FP4 for validated LLM inference recipes [https://docs.nvidia.com/deeplearning/transformer-engine-releases/release-2.13/user-guide/examples/fp8_primer.html]", "use MXFP8 for Blackwell FP8 training recipes on sm_100+ [https://docs.nvidia.com/deeplearning/transformer-engine/user-guide/features/low_precision_training/mxfp8/mxfp8.html]", "use TensorRT-LLM for production serving with paged attention/batching [https://docs.nvidia.com/tensorrt-llm/index.html]", "use HGX NVLink/NVSwitch scale-up before PCIe/IB sharding", "use MIG only for isolated single-GPU tenants; max 7 instances [https://docs.nvidia.com/datacenter/tesla/mig-user-guide/supported-gpus.html]", "target sm_100 for CUDA/CUTLASS extensions", "hybrid Muon+AdamW for matmul-heavy LLM training [https://docs.pytorch.org/docs/2.12/generated/torch.optim.Muon.html]", "Muon for 2D hidden weights; AdamW for embedding/bias/norm/head/non-2D params", "Muon ns_steps=5 momentum=0.95 nesterov=True as initial setting", "Muon adjust_lr_fn=\'match_rms_adamw\' when reusing AdamW LR schedule", "custom CUDA kernels: budget 227KB block shared memory and 64 warps/SM [https://docs.nvidia.com/cuda/blackwell-tuning-guide/index.html]", "custom CUDA kernels: cluster size 16 only for B200-only opt-in path [https://docs.nvidia.com/cuda/blackwell-tuning-guide/index.html]", "evaluate MLOPart/MPS only for latency-sensitive B200 serving A/B tests [https://developer.nvidia.com/blog/boost-gpu-memory-performance-with-no-code-changes-using-nvidia-cuda-mps/]", "use nvCOMP hardware decompression for Snappy/LZ4/Deflate input pipelines [https://developer.nvidia.com/blog/speeding-up-data-decompression-with-nvcomp-and-the-nvidia-blackwell-decompression-engine/]"], "avoid_patterns": ["no 192GB sizing on current DGX/HGX B200 deployments", "no MIG for jobs needing full-GPU collectives", "no topology-blind NCCL plan across NVSwitch/IB boundary", "no FP4 default without accuracy validation", "no CUDA extension missing sm_100 target", "no Muon for embedding/bias/norm/head/non-2D params", "no AdamW LR copied to Muon without adjust_lr_fn or retuning", "no optimizer comparison against undertuned AdamW baseline", "no cluster size 16 in portable CUDA kernels", "no MLOPart for strict tenant isolation; use MIG instead", "no decompression-engine dependency without allocation-type check and nvCOMP fallback"], "memory_bandwidth_GBps": 8000, "source_url": "https://docs.nvidia.com/enterprise-reference-architectures/hgx-ai-factory/latest/components.html"}');
