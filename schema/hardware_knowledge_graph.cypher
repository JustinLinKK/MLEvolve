// hardware-feature knowledge GraphDB. Generated by build_graph_db.py.
// Independent of graph_schema.yaml (the job-evidence graph).
CREATE CONSTRAINT hardware_id IF NOT EXISTS FOR (h:Hardware) REQUIRE h.hardware_id IS UNIQUE;
CREATE CONSTRAINT feature_id IF NOT EXISTS FOR (f:Feature) REQUIRE f.feature_id IS UNIQUE;

MERGE (n:Feature {feature_id: "amp"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "amp", "name": "amp", "category": "precision", "description": "PyTorch Automatic Mixed Precision (torch.amp)", "tensor_core_generation": "", "example_code": "import torch\nimport torch.nn as nn\ndevice = \'cuda\' if torch.cuda.is_available() else \'cpu\'\nmodel = nn.Linear(64, 32).to(device)\nopt = torch.optim.SGD(model.parameters(), lr=1e-3)\nx = torch.randn(8, 64, device=device)\ny = torch.randn(8, 32, device=device)\nopt.zero_grad(set_to_none=True)\nwith torch.autocast(device_type=\'cuda\' if device == \'cuda\' else \'cpu\', dtype=torch.bfloat16):\n    out = model(x)\n    loss = (out - y).pow(2).mean()\nloss.backward()\nopt.step()", "example_code_source": "pytorch.amp.autocast.bf16.training.001", "api_symbols": ["torch.amp.GradScaler", "torch.amp.autocast", "torch.autocast"], "source_url": "https://docs.pytorch.org/docs/stable/amp.html"}');
MERGE (n:Feature {feature_id: "bf16"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "bf16", "name": "bf16", "category": "precision", "description": "CUDA C++ Programming Guide -- bfloat16 floating-point format", "tensor_core_generation": "", "example_code": "import torch\nimport torch.nn as nn\ndevice = \'cuda\' if torch.cuda.is_available() else \'cpu\'\nmodel = nn.Linear(64, 32).to(device)\nopt = torch.optim.SGD(model.parameters(), lr=1e-3)\nx = torch.randn(8, 64, device=device)\ny = torch.randn(8, 32, device=device)\nopt.zero_grad(set_to_none=True)\nwith torch.autocast(device_type=\'cuda\' if device == \'cuda\' else \'cpu\', dtype=torch.bfloat16):\n    out = model(x)\n    loss = (out - y).pow(2).mean()\nloss.backward()\nopt.step()", "example_code_source": "pytorch.amp.autocast.bf16.training.001", "api_symbols": ["torch.amp.GradScaler", "torch.amp.autocast", "torch.autocast", "torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "torch.cuda.get_device_properties"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#bfloat16-floating-point-format"}');
MERGE (n:Feature {feature_id: "cuda_graphs"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "cuda_graphs", "name": "cuda_graphs", "category": "kernel", "description": "CUDA Graphs capture a sequence of kernel launches and their\ndependencies into a single replayable object; the overhead of\ngraph definition and instantiation can then be amortized over many\nexecutions. A graph is a snapshot of a workflow including kernels,\ntheir parameters, and their dependencies, replayed as rapidly as\npossible. Best for workloads with many small kernels and fixed\nlaunch parameters; structures with variable shapes or per-step\ncontrol flow cannot be captured directly. See the CUDA C++\nProgramming Guide CUDA Graphs section for the full set of capture\nrestrictions and the API surface.", "tensor_core_generation": "", "example_code": "import torch\nimport torch.nn as nn\nif not torch.cuda.is_available():\n    raise SystemExit(\'SKIP: no CUDA\')\nmodel = nn.Linear(64, 32).cuda()\nstatic_x = torch.randn(8, 64, device=\'cuda\')\nfor _ in range(3):\n    out = model(static_x)\ntorch.cuda.synchronize()\ng = torch.cuda.CUDAGraph()\nwith torch.cuda.graph(g):\n    out = model(static_x)\ng.replay()\ntorch.cuda.synchronize()", "example_code_source": "cuda.graphs.training_loop.001", "api_symbols": ["torch.cuda.CUDAGraph", "torch.cuda.graph"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#cuda-graphs"}');
MERGE (n:Feature {feature_id: "fp16"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "fp16", "name": "fp16", "category": "precision", "description": "CUDA C++ Programming Guide -- half-precision (FP16) floating-point format", "tensor_core_generation": "", "example_code": "import torch\ncc = torch.cuda.get_device_capability()\ngeneration = {\n    (7, 0): \'1gen (Volta)\',     (7, 5): \'2gen (Turing)\',\n    (8, 0): \'3gen (Ampere DC)\', (8, 6): \'3gen (Ampere)\',\n    (8, 9): \'4gen (Ada)\',       (9, 0): \'4gen (Hopper)\',\n    (10, 0): \'5gen (Blackwell DC)\', (12, 0): \'5gen (Blackwell GeForce)\',\n}.get(cc, f\'unknown (CC {cc[0]}.{cc[1]})\')\nprint(f\'GPU CC={cc[0]}.{cc[1]}, tensor core {generation}\')\nprint(f\'compiled archs: {torch.cuda.get_arch_list()}\')", "example_code_source": "nvidia.tensor_cores.generations.001", "api_symbols": ["torch.autocast", "torch.cuda.amp.GradScaler", "torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "torch.cuda.get_device_properties"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#half-precision-floating-point-format"}');
MERGE (n:Feature {feature_id: "fp4"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "fp4", "name": "fp4", "category": "precision", "description": "NVIDIA GeForce RTX 5090 (FP4 + 5th-gen Tensor Cores)", "tensor_core_generation": "", "example_code": "import torch\ncc = torch.cuda.get_device_capability()\n# FP4 tensor cores live on sm_100 (Blackwell DC) and sm_120 (Blackwell GeForce).\nif cc < (10, 0):\n    raise SystemExit(\n        f\'fp4 unsupported on CC {cc[0]}.{cc[1]} \'\n        \'(requires Blackwell sm_100 or sm_120)\'\n    )\n# Inference-only example. Real call sites use NVIDIA Transformer Engine\n# or TensorRT-LLM with an MXFP4 recipe. PyTorch native fp4 autocast\n# does not exist (as of torch 2.12); MXFP4 is reached via te.fp8_autocast\n# with a Format.MXFP4 recipe in recent transformer_engine releases.\nprint(f\'GPU CC={cc[0]}.{cc[1]} supports MXFP4 inference via Transformer Engine\')", "example_code_source": "nvidia.fp4.blackwell.001", "api_symbols": ["torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://www.nvidia.com/en-us/geforce/graphics-cards/50-series/rtx-5090/"}');
MERGE (n:Feature {feature_id: "fp64"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "fp64", "name": "fp64", "category": "precision", "description": "CUDA C++ Programming Guide -- double-precision (FP64) floating-point format", "tensor_core_generation": "", "example_code": "", "example_code_source": "", "api_symbols": [], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#double-precision-floating-point-format"}');
MERGE (n:Feature {feature_id: "fp8"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "fp8", "name": "fp8", "category": "precision", "description": "FP8 Formats for Deep Learning (Micikevicius et al., 2022)", "tensor_core_generation": "", "example_code": "import torch\nif not torch.cuda.is_available():\n    raise SystemExit(\'SKIP: no CUDA\')\ncc = torch.cuda.get_device_capability()\n# FP8 Tensor Cores require compute capability >= 8.9 (Ada / Hopper / Blackwell)\nif cc < (8, 9):\n    raise SystemExit(\n        f\'SKIP: fp8 requires CC >= 8.9, got {cc[0]}.{cc[1]}\'\n    )\ntry:\n    import transformer_engine.pytorch as te\n    from transformer_engine.common.recipe import DelayedScaling, Format\nexcept ImportError:\n    raise SystemExit(\'SKIP: transformer_engine not installed\')\nrecipe = DelayedScaling(\n    margin=0,\n    fp8_format=Format.HYBRID,    # forward=E4M3, backward=E5M2\n    amax_history_len=16,\n    amax_compute_algo=\'max\',\n)\nte_model = te.Linear(64, 32).cuda()\nx = torch.randn(8, 64, device=\'cuda\')\nwith te.fp8_autocast(enabled=True, fp8_recipe=recipe):\n    out = te_model(x)", "example_code_source": "nvidia.fp8.e4m3_vs_e5m2.001", "api_symbols": ["torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "torch.cuda.get_device_properties", "transformer_engine.common.recipe.DelayedScaling", "transformer_engine.common.recipe.Format", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://arxiv.org/abs/2209.05433"}');
MERGE (n:Feature {feature_id: "fp8_e4m3"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "fp8_e4m3", "name": "fp8_e4m3", "category": "precision", "description": "FP8 Formats for Deep Learning -- E4M3 variant (Micikevicius et al., 2022)", "tensor_core_generation": "", "example_code": "import torch\nif not torch.cuda.is_available():\n    raise SystemExit(\'SKIP: no CUDA\')\ncc = torch.cuda.get_device_capability()\n# FP8 Tensor Cores require compute capability >= 8.9 (Ada / Hopper / Blackwell)\nif cc < (8, 9):\n    raise SystemExit(\n        f\'SKIP: fp8 requires CC >= 8.9, got {cc[0]}.{cc[1]}\'\n    )\ntry:\n    import transformer_engine.pytorch as te\n    from transformer_engine.common.recipe import DelayedScaling, Format\nexcept ImportError:\n    raise SystemExit(\'SKIP: transformer_engine not installed\')\nrecipe = DelayedScaling(\n    margin=0,\n    fp8_format=Format.HYBRID,    # forward=E4M3, backward=E5M2\n    amax_history_len=16,\n    amax_compute_algo=\'max\',\n)\nte_model = te.Linear(64, 32).cuda()\nx = torch.randn(8, 64, device=\'cuda\')\nwith te.fp8_autocast(enabled=True, fp8_recipe=recipe):\n    out = te_model(x)", "example_code_source": "nvidia.fp8.e4m3_vs_e5m2.001", "api_symbols": ["torch.cuda.get_device_capability", "torch.cuda.get_device_properties", "transformer_engine.common.recipe.DelayedScaling", "transformer_engine.common.recipe.Format", "transformer_engine.pytorch.Linear", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://arxiv.org/abs/2209.05433"}');
MERGE (n:Feature {feature_id: "fp8_e5m2"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "fp8_e5m2", "name": "fp8_e5m2", "category": "precision", "description": "FP8 Formats for Deep Learning -- E5M2 variant (Micikevicius et al., 2022)", "tensor_core_generation": "", "example_code": "import torch\nif not torch.cuda.is_available():\n    raise SystemExit(\'SKIP: no CUDA\')\ncc = torch.cuda.get_device_capability()\n# FP8 Tensor Cores require compute capability >= 8.9 (Ada / Hopper / Blackwell)\nif cc < (8, 9):\n    raise SystemExit(\n        f\'SKIP: fp8 requires CC >= 8.9, got {cc[0]}.{cc[1]}\'\n    )\ntry:\n    import transformer_engine.pytorch as te\n    from transformer_engine.common.recipe import DelayedScaling, Format\nexcept ImportError:\n    raise SystemExit(\'SKIP: transformer_engine not installed\')\nrecipe = DelayedScaling(\n    margin=0,\n    fp8_format=Format.HYBRID,    # forward=E4M3, backward=E5M2\n    amax_history_len=16,\n    amax_compute_algo=\'max\',\n)\nte_model = te.Linear(64, 32).cuda()\nx = torch.randn(8, 64, device=\'cuda\')\nwith te.fp8_autocast(enabled=True, fp8_recipe=recipe):\n    out = te_model(x)", "example_code_source": "nvidia.fp8.e4m3_vs_e5m2.001", "api_symbols": ["torch.cuda.get_device_capability", "torch.cuda.get_device_properties", "transformer_engine.common.recipe.DelayedScaling", "transformer_engine.common.recipe.Format", "transformer_engine.pytorch.Linear", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://arxiv.org/abs/2209.05433"}');
MERGE (n:Feature {feature_id: "int8"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "int8", "name": "int8", "category": "precision", "description": "PyTorch Quantization (INT8 quantized inference)", "tensor_core_generation": "", "example_code": "import torch\nimport torch.nn as nn\nfrom torch.ao.quantization import quantize_dynamic\nfp32_model = nn.Sequential(nn.Linear(128, 256), nn.ReLU(), nn.Linear(256, 10))\nint8_model = quantize_dynamic(fp32_model, {nn.Linear}, dtype=torch.qint8)\nx = torch.randn(4, 128)\nout = int8_model(x)", "example_code_source": "nvidia.int8.quantization.training.001", "api_symbols": ["torch.ao.quantization.prepare", "torch.ao.quantization.quantize_dynamic", "torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "torch.cuda.get_device_properties"], "source_url": "https://pytorch.org/docs/stable/quantization.html"}');
