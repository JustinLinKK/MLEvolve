MERGE (n:Feature {feature_id: "sm_100"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "sm_100", "name": "sm_100", "category": "compute_capability", "description": "CUDA C++ Programming Guide -- Compute Capability (sm_100, Blackwell datacenter)", "tensor_core_generation": "", "example_code": "import torch\ncc = torch.cuda.get_device_capability()\n# FP4 tensor cores live on sm_100 (Blackwell DC) and sm_120 (Blackwell GeForce).\nif cc < (10, 0):\n    raise SystemExit(\n        f\'fp4 unsupported on CC {cc[0]}.{cc[1]} \'\n        \'(requires Blackwell sm_100 or sm_120)\'\n    )\n# Inference-only example. Real call sites use NVIDIA Transformer Engine\n# or TensorRT-LLM with an MXFP4 recipe. PyTorch native fp4 autocast\n# does not exist (as of torch 2.12); MXFP4 is reached via te.fp8_autocast\n# with a Format.MXFP4 recipe in recent transformer_engine releases.\nprint(f\'GPU CC={cc[0]}.{cc[1]} supports MXFP4 inference via Transformer Engine\')", "example_code_source": "nvidia.fp4.blackwell.001", "api_symbols": ["torch.cuda.get_device_capability", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#compute-capability"}');
MERGE (n:Feature {feature_id: "sm_120"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "sm_120", "name": "sm_120", "category": "compute_capability", "description": "CUDA C++ Programming Guide -- Compute Capability (sm_120, Blackwell consumer)", "tensor_core_generation": "", "example_code": "import torch\nimport torch.nn.functional as F\ndevice = \'cuda\' if torch.cuda.is_available() else \'cpu\'\nB, H, S, D = 1, 4, 128, 64\ndtype = torch.bfloat16 if device == \'cuda\' else torch.float32\nq = torch.randn(B, H, S, D, device=device, dtype=dtype)\nk = torch.randn(B, H, S, D, device=device, dtype=dtype)\nv = torch.randn(B, H, S, D, device=device, dtype=dtype)\nout = F.scaled_dot_product_attention(q, k, v, is_causal=True)", "example_code_source": "flash_attn.v3.usage.001", "api_symbols": ["flash_attn.flash_attn_func", "torch.cuda.get_device_capability", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#compute-capability"}');
