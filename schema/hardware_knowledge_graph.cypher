MERGE (n:Hardware {hardware_id: "nvidia.hopper.h100_sxm5_80gb.spec"}) SET n += apoc.convert.fromJsonMap('{"hardware_id": "nvidia.hopper.h100_sxm5_80gb.spec", "name": "NVIDIA H100 SXM5 80GB", "vendor": "nvidia", "aliases": ["h100_sxm5_80gb"], "architectures": ["hopper"], "compute_capabilities": ["9.0"], "vram_MB": 81920, "vram_type": "hbm3", "sm_count": 132, "workload_types": ["vision_training", "transformer_training", "generative_ai", "llm_training", "hpc", "matmul_heavy", "transformer_inference", "vision_inference"], "recommended_patterns": ["Keep batch size, precision, accumulation in top-level config", "bf16 autocast default for training", "fp8 training+inference via transformer_engine (E4M3 fwd, E5M2 grad)", "TF32 on for FP32 matmul", "cudnn.benchmark=True", "FP64 OK on this chip (1:2 ratio)", "NVLink + NCCL for multi-GPU", "MIG up to 7 partitions for inference", "flash-attn v3 (sm_90 native)", "cap peak VRAM at 80896 MiB per job"], "avoid_patterns": ["no FP4 (Blackwell-only)", "no 5gen tensor cores (4gen only on Hopper)"]}');
MERGE (n:Hardware {hardware_id: "nvidia.hopper.h200_sxm_141gb.spec"}) SET n += apoc.convert.fromJsonMap('{"hardware_id": "nvidia.hopper.h200_sxm_141gb.spec", "name": "NVIDIA H200 SXM 141GB", "vendor": "nvidia", "aliases": ["h200_sxm_141gb"], "architectures": ["hopper"], "compute_capabilities": ["9.0"], "vram_MB": 144384, "vram_type": "hbm3e", "sm_count": 132, "workload_types": ["vision_training", "transformer_training", "generative_ai", "llm_training", "hpc", "matmul_heavy", "transformer_inference", "vision_inference"], "recommended_patterns": ["Keep batch size, precision, accumulation in top-level config", "bf16 autocast default", "fp8 training+inference via transformer_engine (E4M3 fwd, E5M2 grad)", "TF32 on for FP32 matmul", "cudnn.benchmark=True for static shapes", "FP64 OK on this chip (1:2 ratio)", "fit larger batches given 141 GiB HBM3e", "NVLink for multi-GPU all_reduce", "MIG up to 7 partitions for inference", "flash-attn v3", "cap peak VRAM at 143360 MiB per job"], "avoid_patterns": ["no FP4 (Blackwell-only)"]}');
MERGE (n:Feature {feature_id: "cut_cross_entropy"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "cut_cross_entropy", "name": "cut_cross_entropy", "category": "kernel_optimization", "description": "Cut Cross-Entropy: fuses a linear classifier/logit projection with the cross-entropy loss so the (N x V) logits tensor is never materialized in global memory [https://github.com/apple/ml-cross-entropy]; chunked online log-sum-exp in SRAM. Same math (exact CE + gradient), >4x peak-memory cut on large-vocab heads, >2x kernel speed.", "tensor_core_generation": "benefits_from_tensor_core_lm_head_gemm", "example_code": "import torch\nfrom cut_cross_entropy import linear_cross_entropy\n\nB, T, D, V = 2, 16, 1024, 32000\nembeddings = torch.randn(B, T, D, device=\'cuda\', dtype=torch.bfloat16, requires_grad=True)\nclassifier = torch.randn(V, D, device=\'cuda\', dtype=torch.bfloat16, requires_grad=True)\nlabels = torch.randint(0, V, (B, T), device=\'cuda\')\nloss = linear_cross_entropy(embeddings, classifier, labels, shift=1)\nloss.backward()", "example_code_source": "apple.ml_cross_entropy.readme.basic_usage.001", "api_symbols": ["cut_cross_entropy.linear_cross_entropy", "cut_cross_entropy.transformers.cce_patch"], "source_url": "https://arxiv.org/abs/2411.09009"}');
MERGE (n:Feature {feature_id: "muon_optimizer"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "muon_optimizer", "name": "muon_optimizer", "category": "optimizer", "description": "Muon optimizer: for 2D weight matrices, replaces the momentum-smoothed gradient with its nearest semi-orthogonal matrix via a fixed 5-step Newton-Schulz iteration (no SVD); 1D params stay on AdamW. Matches AdamW final loss using ~52% of training FLOPs.", "tensor_core_generation": "not_required; NS/GEMM-heavy optimizer step can benefit from fast matmul", "example_code": "import torch\n\nmuon_params = []\nadamw_params = []\nfor name, p in model.named_parameters():\n    if not p.requires_grad:\n        continue\n    is_hidden_2d = p.ndim == 2 and \'embed\' not in name and \'lm_head\' not in name\n    if is_hidden_2d:\n        muon_params.append(p)\n    else:\n        adamw_params.append(p)\n\noptim_muon = torch.optim.Muon(muon_params, lr=0.02, weight_decay=0.1, momentum=0.95, nesterov=True, ns_steps=5, adjust_lr_fn=\'match_rms_adamw\')\noptim_adamw = torch.optim.AdamW(adamw_params, lr=3e-4, weight_decay=0.01)\n\noptim_muon.zero_grad()\noptim_adamw.zero_grad()\nloss.backward()\noptim_muon.step()\noptim_adamw.step()", "example_code_source": "pytorch.2_12.optim_muon.hybrid_adamw.001", "api_symbols": ["torch.optim.Muon", "torch.optim.AdamW"], "source_url": "https://arxiv.org/abs/2502.16982"}');
MERGE (n:Feature {feature_id: "soap_optimizer"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "soap_optimizer", "name": "soap_optimizer", "category": "optimizer", "description": "SOAP optimizer: Shampoo run in the eigenbasis of its own preconditioner, then plain Adam in that rotated space; amortizes eigendecomposition. >40% fewer iterations / >35% wall-clock vs AdamW to same loss in large-batch regime.", "tensor_core_generation": "not_required; preconditioner math is matrix-operation heavy", "example_code": "from soap import SOAP\n\noptim = SOAP(model.parameters(), lr=3e-3, betas=(0.95, 0.95), weight_decay=0.01, precondition_frequency=10)\noptim.zero_grad()\nloss.backward()\noptim.step()", "example_code_source": "nikhilvyas.soap.readme.basic_usage.001", "api_symbols": ["soap.SOAP"], "source_url": "https://arxiv.org/abs/2409.11321"}');
MERGE (n:Feature {feature_id: "ademamix_optimizer"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "ademamix_optimizer", "name": "ademamix_optimizer", "category": "optimizer", "description": "AdEMAMix optimizer: augments Adam\'s fast gradient EMA with a second very-slow EMA (beta3 ~0.9999). A 1.3B model on 101B tokens matches AdamW on 197B (~51% token reduction to same loss). One extra EMA buffer.", "tensor_core_generation": "", "example_code": "from ademamix import AdEMAMix\n\nnum_iterations = 256000\noptim = AdEMAMix(params=model.parameters(), lr=1e-3, betas=(0.9, 0.999, 0.9999), alpha=8.0, beta3_warmup=num_iterations, alpha_warmup=num_iterations, weight_decay=0.1)\noptim.zero_grad()\nloss.backward()\noptim.step()", "example_code_source": "apple.ml_ademamix.readme.pytorch_usage.001", "api_symbols": ["ademamix.AdEMAMix"], "source_url": "https://arxiv.org/abs/2409.03137"}');
MERGE (n:Feature {feature_id: "dataset_decomposition"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "dataset_decomposition", "name": "dataset_decomposition", "category": "data_pipeline", "description": "Dataset Decomposition: decompose corpus into same-length buckets and train a short-to-long variable-sequence-length curriculum with only intra-document attention. Changes data ordering not model/loss; reaches target accuracy up to 6x faster than fixed-length concatenation.", "tensor_core_generation": "", "example_code": "def decompose_documents(tokenized_docs, bucket_lengths=(128, 256, 512, 1024, 2048)):\n    buckets = {L: [] for L in bucket_lengths}\n    for doc in tokenized_docs:\n        n = len(doc)\n        for L in bucket_lengths:\n            for start in range(0, n - L + 1, L):\n                # never concatenate across documents\n                buckets[L].append(doc[start:start + L])\n    return buckets\n\ndef sample_curriculum_bucket(buckets, step, total_steps):\n    lengths = sorted([L for L, seqs in buckets.items() if seqs])\n    max_idx = max(0, int((len(lengths) - 1) * step / max(1, total_steps - 1)))\n    active_lengths = lengths[:max_idx + 1]\n    return active_lengths[-1]", "example_code_source": "paper.dataset_decomposition.conceptual_bucket_curriculum.001", "api_symbols": [], "source_url": "https://arxiv.org/abs/2405.13226"}');
MERGE (n:Feature {feature_id: "gram_newton_schulz_symmetric_gemm"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "gram_newton_schulz_symmetric_gemm", "name": "gram_newton_schulz_symmetric_gemm", "category": "kernel_optimization", "description": "Gram Newton-Schulz symmetric/triangular fused GEMM: the Newton-Schulz step (used by Muon) is a symmetric product; a triangular fused kernel removes the wasted half of multiplies plus a DRAM round-trip cuBLAS incurs. Up to 2x faster NS step. Same math (Gram-matrix restart guards stability).", "tensor_core_generation": "tensor_core_compatible; benefits_from_symmetric_gemm_kernel", "example_code": "import torch\n\n# Conceptual fallback only. Production use should call the fused symmetric/triangular GEMM kernel.\ndef gram_newton_schulz_reference(X, ns_steps=5, eps=1e-7):\n    X = X / (X.norm() + eps)\n    wide = X.shape[0] < X.shape[1]\n    for _ in range(ns_steps):\n        if wide:\n            G = X @ X.T\n            X = 1.5 * X - 0.5 * (G @ X)\n        else:\n            G = X.T @ X\n            X = 1.5 * X - 0.5 * (X @ G)\n    return X\n\nupdate = gram_newton_schulz_reference(momentum_matrix)", "example_code_source": "gram_newton_schulz.reference_fallback.001", "api_symbols": ["custom_kernel:gram_newton_schulz", "custom_kernel:symmetric_gemm", "custom_kernel:triangular_fused_gemm"], "source_url": "https://tridao.me/blog/2026/gram-newton-schulz/"}');
MERGE (n:Feature {feature_id: "nvimagecodec_gpu_decode"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "nvimagecodec_gpu_decode", "name": "nvimagecodec_gpu_decode", "category": "data_pipeline", "description": "nvImageCodec GPU image decode: decodes encoded image bytes (nvJPEG/nvJPEG2000/nvTIFF plus hardware JPEG decode on documented nvJPEG hardware [https://docs.nvidia.com/cuda/nvjpeg/index.html]) directly into GPU memory, DLPack zero-copy to torch, decode of batch N+1 overlapping compute of batch N. Removes CPU-decode bottleneck for CV/imaging. ~2.18x faster JPEG loading. No-op for text/LLM training.", "tensor_core_generation": "", "example_code": "import torch\nfrom nvidia import nvimgcodec\n\ndecoder = nvimgcodec.Decoder()\nnv_img = decoder.read(\'sample.jp2\')\ncap = nv_img.to_dlpack()\ntorch_img = torch.from_dlpack(cap)\nassert torch_img.is_cuda\nbatch = torch_img.permute(2, 0, 1).unsqueeze(0).contiguous()", "example_code_source": "nvidia.nvimagecodec.samples.torch_dlpack.001", "api_symbols": ["nvidia.nvimgcodec.Decoder", "nvidia.nvimgcodec.Encoder", "nvidia.nvimgcodec.Image.to_dlpack", "nvidia.nvimgcodec.as_image", "torch.from_dlpack", "torch.to_dlpack"], "source_url": "https://docs.nvidia.com/cuda/nvimagecodec/samples/torch.html"}');
MERGE (n:Feature {feature_id: "async_tensor_parallel"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "async_tensor_parallel", "name": "async_tensor_parallel", "category": "parallelism", "description": "Asynchronous tensor-parallel communication overlap (PyTorch SymmetricMemory): uses eligible NCCL Copy Engine collectives such as all_gather_into_tensor/all_to_all_single on symmetric-memory tensors so communication can overlap compute. Multi-GPU only; no effect single-GPU. Same math.", "tensor_core_generation": "", "example_code": "import os\nimport torch\nimport torch.distributed as dist\nimport torch.distributed._symmetric_memory as symm_mem\n\nrank = int(os.environ.get(\'LOCAL_RANK\', \'0\'))\ndevice = torch.device(\'cuda\', rank)\nopts = dist.ProcessGroupNCCL.Options()\nopts.config.cta_policy = dist.ProcessGroupNCCL.NCCL_CTA_POLICY_ZERO\ndist.init_process_group(backend=\'nccl\', pg_options=opts, device_id=device)\nworld_size = dist.get_world_size()\n\nsymm_mem.set_backend(\'NCCL\')\ngroup_name = dist.group.WORLD.group_name\ninp = symm_mem.empty(1024 * 1024, device=device)\nout = symm_mem.empty(1024 * 1024 * world_size, device=device)\nsymm_mem.rendezvous(inp, group=group_name)\nsymm_mem.rendezvous(out, group=group_name)\nwork = dist.all_gather_into_tensor(out, inp, async_op=True)\n# compute can be scheduled here on independent work\nwork.wait()", "example_code_source": "pytorch.2_12.symmetric_memory.copy_engine_collective.001", "api_symbols": ["torch.distributed.ProcessGroupNCCL.Options", "torch.distributed.ProcessGroupNCCL.NCCL_CTA_POLICY_ZERO", "torch.distributed.init_process_group", "torch.distributed._symmetric_memory.empty", "torch.distributed._symmetric_memory.rendezvous", "torch.distributed._symmetric_memory.set_backend", "torch.distributed.all_gather_into_tensor", "torch.distributed.all_to_all_single"], "source_url": "https://docs.pytorch.org/docs/2.12/symmetric_memory.html"}');
MERGE (n:Feature {feature_id: "fp8_rowwise_scaling"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "fp8_rowwise_scaling", "name": "fp8_rowwise_scaling", "category": "precision", "description": "FP8 row-wise (per-token) scaling: one fp8 scale factor per row of each operand instead of per-tensor; a single outlier row no longer forces a coarse scale that underflows the rest. Strictly more accuracy-preserving than per-tensor fp8; loss parity with bf16. GEMMs still on fp8 Tensor Cores (~1.11x over bf16 H100). Available via torchao.", "tensor_core_generation": "4th_generation_or_later_fp8_tensor_cores", "example_code": "import torch\nfrom torch import nn\nfrom torchao.float8 import convert_to_float8_training, Float8LinearConfig, Float8LinearRecipeName\n\nmodel = nn.Sequential(nn.Linear(2048, 4096), nn.GELU(), nn.Linear(4096, 2048)).bfloat16().cuda()\nconfig = Float8LinearConfig.from_recipe_name(Float8LinearRecipeName.ROWWISE)\nconvert_to_float8_training(model, config=config)\nmodel = torch.compile(model)\nx = torch.randn(16, 2048, device=\'cuda\', dtype=torch.bfloat16)\ny = model(x)", "example_code_source": "torchao.0_17.float8_rowwise_training.001", "api_symbols": ["torchao.float8.convert_to_float8_training", "torchao.float8.Float8LinearConfig", "torchao.float8.Float8LinearConfig.from_recipe_name", "torchao.float8.Float8LinearRecipeName.ROWWISE"], "source_url": "https://docs.pytorch.org/ao/stable/eager_tutorials/pretraining.html"}');
MERGE (n:Feature {feature_id: "fp8_all_gather_fsdp2"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "fp8_all_gather_fsdp2", "name": "fp8_all_gather_fsdp2", "category": "parallelism", "description": "FP8 all-gather in FSDP2: shards and all-gathers parameters in fp8 instead of bf16, halving the sharded-parameter communication volume in distributed training. Multi-GPU only. Built on torchao float8 + FSDP2.", "tensor_core_generation": "4th_generation_or_later_fp8_tensor_cores", "example_code": "import torch\nfrom torch import nn\nfrom torchao.float8 import convert_to_float8_training, Float8LinearConfig, Float8LinearRecipeName\n\nmodel = nn.Sequential(nn.Linear(4096, 4096), nn.GELU(), nn.Linear(4096, 4096)).bfloat16().cuda()\nconfig = Float8LinearConfig.from_recipe_name(Float8LinearRecipeName.TENSORWISE)\nconfig.enable_fsdp_float8_all_gather = True\nconvert_to_float8_training(model, config=config)\n# Apply FSDP2/fully_shard outside this snippet in distributed setup.", "example_code_source": "torchao.0_17.float8_config.fsdp_all_gather.001", "api_symbols": ["torchao.float8.Float8LinearConfig", "torchao.float8.Float8LinearConfig.enable_fsdp_float8_all_gather", "torchao.float8.convert_to_float8_training", "torch.distributed.fsdp.fully_shard"], "source_url": "https://docs.pytorch.org/ao/stable/api_reference/generated/torchao.float8.Float8LinearConfig.html"}');

