MERGE (n:Feature {feature_id: "sm_100"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "sm_100", "name": "sm_100", "category": "compute_capability", "description": "CUDA C++ Programming Guide -- Compute Capability (sm_100, Blackwell datacenter)", "tensor_core_generation": "", "example_code": "import torch\ncc = torch.cuda.get_device_capability()\n# FP4 tensor cores live on sm_100 (Blackwell DC) and sm_120 (Blackwell GeForce).\nif cc < (10, 0):\n    raise SystemExit(\n        f\'fp4 unsupported on CC {cc[0]}.{cc[1]} \'\n        \'(requires Blackwell sm_100 or sm_120)\'\n    )\n# Inference-only example. Real call sites use NVIDIA Transformer Engine\n# or TensorRT-LLM with an MXFP4 recipe. PyTorch native fp4 autocast\n# does not exist (as of torch 2.12); MXFP4 is reached via te.fp8_autocast\n# with a Format.MXFP4 recipe in recent transformer_engine releases.\nprint(f\'GPU CC={cc[0]}.{cc[1]} supports MXFP4 inference via Transformer Engine\')", "example_code_source": "nvidia.fp4.blackwell.001", "api_symbols": ["torch.cuda.get_device_capability", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#compute-capability"}');
MERGE (n:Feature {feature_id: "sm_120"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "sm_120", "name": "sm_120", "category": "compute_capability", "description": "CUDA C++ Programming Guide -- Compute Capability (sm_120, Blackwell consumer)", "tensor_core_generation": "", "example_code": "import torch\nimport torch.nn.functional as F\ndevice = \'cuda\' if torch.cuda.is_available() else \'cpu\'\nB, H, S, D = 1, 4, 128, 64\ndtype = torch.bfloat16 if device == \'cuda\' else torch.float32\nq = torch.randn(B, H, S, D, device=device, dtype=dtype)\nk = torch.randn(B, H, S, D, device=device, dtype=dtype)\nv = torch.randn(B, H, S, D, device=device, dtype=dtype)\nout = F.scaled_dot_product_attention(q, k, v, is_causal=True)", "example_code_source": "flash_attn.v3.usage.001", "api_symbols": ["flash_attn.flash_attn_func", "torch.cuda.get_device_capability", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#compute-capability"}');
MERGE (n:Feature {feature_id: "sm_80"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "sm_80", "name": "sm_80", "category": "compute_capability", "description": "CUDA C++ Programming Guide -- Compute Capability (sm_80, Ampere)", "tensor_core_generation": "", "example_code": "", "example_code_source": "", "api_symbols": [], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#compute-capability"}');
MERGE (n:Feature {feature_id: "sm_86"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "sm_86", "name": "sm_86", "category": "compute_capability", "description": "CUDA C++ Programming Guide -- Compute Capability (sm_86, Ampere consumer)", "tensor_core_generation": "", "example_code": "", "example_code_source": "", "api_symbols": [], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#compute-capability"}');
MERGE (n:Feature {feature_id: "sm_89"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "sm_89", "name": "sm_89", "category": "compute_capability", "description": "CUDA C++ Programming Guide -- Compute Capability (sm_89, Ada Lovelace)", "tensor_core_generation": "", "example_code": "import torch\np = torch.cuda.get_device_properties(0)\nassert (p.major, p.minor) == (8, 9), f\'expected Ada Lovelace CC 8.9, got {p.major}.{p.minor}\'\nprint(f\'{p.name}: SMs={p.multi_processor_count}, VRAM={p.total_memory // 1024 // 1024} MiB\')", "example_code_source": "nvidia.ada_lovelace.architecture.001", "api_symbols": ["torch.cuda.get_device_capability", "torch.cuda.get_device_properties"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#compute-capability"}');
MERGE (n:Feature {feature_id: "sm_90"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "sm_90", "name": "sm_90", "category": "compute_capability", "description": "CUDA C++ Programming Guide -- Compute Capability (sm_90, Hopper)", "tensor_core_generation": "", "example_code": "import torch\nimport torch.nn.functional as F\ndevice = \'cuda\' if torch.cuda.is_available() else \'cpu\'\nB, H, S, D = 1, 4, 128, 64\ndtype = torch.bfloat16 if device == \'cuda\' else torch.float32\nq = torch.randn(B, H, S, D, device=device, dtype=dtype)\nk = torch.randn(B, H, S, D, device=device, dtype=dtype)\nv = torch.randn(B, H, S, D, device=device, dtype=dtype)\nout = F.scaled_dot_product_attention(q, k, v, is_causal=True)", "example_code_source": "flash_attn.v3.usage.001", "api_symbols": ["flash_attn.flash_attn_func"], "source_url": "https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#compute-capability"}');
MERGE (n:Feature {feature_id: "tensor_cores"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "tensor_cores", "name": "tensor_cores", "category": "tensor_core", "description": "Set torch.backends.cudnn.benchmark=True so that when a cuDNN\nconvolution is called with a new set of size parameters, cuDNN runs\nmultiple algorithms, benchmarks them to find the fastest one, and\nreuses it for the rest of the process for the same size parameters.\nDisabling it (benchmark=False) makes cuDNN deterministically select\nan algorithm, possibly at the cost of reduced performance. The\nseparate torch.backends.cudnn.deterministic flag controls\nreproducibility and is distinct from the benchmark setting; combine\nit with seeded RNGs (Python, NumPy, PyTorch) when you need\nreproducible runs.", "tensor_core_generation": "", "example_code": "import torch\ncc = torch.cuda.get_device_capability()\ngeneration = {\n    (7, 0): \'1gen (Volta)\',     (7, 5): \'2gen (Turing)\',\n    (8, 0): \'3gen (Ampere DC)\', (8, 6): \'3gen (Ampere)\',\n    (8, 9): \'4gen (Ada)\',       (9, 0): \'4gen (Hopper)\',\n    (10, 0): \'5gen (Blackwell DC)\', (12, 0): \'5gen (Blackwell GeForce)\',\n}.get(cc, f\'unknown (CC {cc[0]}.{cc[1]})\')\nprint(f\'GPU CC={cc[0]}.{cc[1]}, tensor core {generation}\')\nprint(f\'compiled archs: {torch.cuda.get_arch_list()}\')", "example_code_source": "nvidia.tensor_cores.generations.001", "api_symbols": ["flash_attn.flash_attn_func", "torch._dynamo.config", "torch.amp.GradScaler", "torch.amp.autocast", "torch.ao.quantization.prepare", "torch.ao.quantization.quantize_dynamic", "torch.autocast", "torch.backends.cuda.matmul.allow_tf32", "torch.backends.cudnn.allow_tf32", "torch.backends.cudnn.benchmark", "torch.backends.cudnn.deterministic", "torch.compile", "torch.cuda.amp.GradScaler", "torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "torch.cuda.get_device_properties", "transformer_engine.pytorch.Linear", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://www.nvidia.com/en-us/data-center/tensor-cores/"}');
MERGE (n:Feature {feature_id: "tensor_cores_3gen"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "tensor_cores_3gen", "name": "tensor_cores_3gen", "category": "tensor_core", "description": "NVIDIA Ampere Architecture Whitepaper (3rd-generation Tensor Cores)", "tensor_core_generation": "tensor_cores_3gen", "example_code": "import torch\nimport torch.nn as nn\nfrom torch.ao.quantization import quantize_dynamic\nfp32_model = nn.Sequential(nn.Linear(128, 256), nn.ReLU(), nn.Linear(256, 10))\nint8_model = quantize_dynamic(fp32_model, {nn.Linear}, dtype=torch.qint8)\nx = torch.randn(4, 128)\nout = int8_model(x)", "example_code_source": "nvidia.int8.quantization.training.001", "api_symbols": ["torch.ao.quantization.prepare", "torch.ao.quantization.quantize_dynamic", "torch.cuda.get_arch_list", "torch.cuda.get_device_capability"], "source_url": "https://images.nvidia.com/aem-dam/en-zz/Solutions/data-center/nvidia-ampere-architecture-whitepaper.pdf"}');
MERGE (n:Feature {feature_id: "tensor_cores_4gen"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "tensor_cores_4gen", "name": "tensor_cores_4gen", "category": "tensor_core", "description": "NVIDIA Hopper H100 Architecture Whitepaper (4th-generation Tensor Cores)", "tensor_core_generation": "tensor_cores_4gen", "example_code": "import torch\nimport torch.nn as nn\nfrom torch.ao.quantization import quantize_dynamic\nfp32_model = nn.Sequential(nn.Linear(128, 256), nn.ReLU(), nn.Linear(256, 10))\nint8_model = quantize_dynamic(fp32_model, {nn.Linear}, dtype=torch.qint8)\nx = torch.randn(4, 128)\nout = int8_model(x)", "example_code_source": "nvidia.int8.quantization.training.001", "api_symbols": ["torch.ao.quantization.prepare", "torch.ao.quantization.quantize_dynamic", "torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "torch.cuda.get_device_properties", "transformer_engine.common.recipe.DelayedScaling", "transformer_engine.common.recipe.Format", "transformer_engine.pytorch.Linear", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://resources.nvidia.com/en-us-tensor-core/gtc22-whitepaper-hopper"}');
MERGE (n:Feature {feature_id: "tensor_cores_5gen"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "tensor_cores_5gen", "name": "tensor_cores_5gen", "category": "tensor_core", "description": "NVIDIA Blackwell Architecture Technical Brief (5th-generation Tensor Cores)", "tensor_core_generation": "tensor_cores_5gen", "example_code": "import torch\ncc = torch.cuda.get_device_capability()\n# FP4 tensor cores live on sm_100 (Blackwell DC) and sm_120 (Blackwell GeForce).\nif cc < (10, 0):\n    raise SystemExit(\n        f\'fp4 unsupported on CC {cc[0]}.{cc[1]} \'\n        \'(requires Blackwell sm_100 or sm_120)\'\n    )\n# Inference-only example. Real call sites use NVIDIA Transformer Engine\n# or TensorRT-LLM with an MXFP4 recipe. PyTorch native fp4 autocast\n# does not exist (as of torch 2.12); MXFP4 is reached via te.fp8_autocast\n# with a Format.MXFP4 recipe in recent transformer_engine releases.\nprint(f\'GPU CC={cc[0]}.{cc[1]} supports MXFP4 inference via Transformer Engine\')", "example_code_source": "nvidia.fp4.blackwell.001", "api_symbols": ["torch.ao.quantization.prepare", "torch.ao.quantization.quantize_dynamic", "torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "transformer_engine.common.recipe.DelayedScaling", "transformer_engine.common.recipe.Format", "transformer_engine.pytorch.Linear", "transformer_engine.pytorch.fp8_autocast"], "source_url": "https://resources.nvidia.com/en-us-blackwell-architecture/blackwell-architecture-technical-brief"}');
MERGE (n:Feature {feature_id: "tf32"}) SET n += apoc.convert.fromJsonMap('{"feature_id": "tf32", "name": "tf32", "category": "precision", "description": "NVIDIA TensorFloat-32 (TF32) precision format announcement", "tensor_core_generation": "", "example_code": "import torch\ntorch.backends.cuda.matmul.allow_tf32 = True\ntorch.backends.cudnn.allow_tf32 = True\ndevice = \'cuda\' if torch.cuda.is_available() else \'cpu\'\na = torch.randn(256, 256, device=device)\nb = torch.randn(256, 256, device=device)\nc = a @ b", "example_code_source": "nvidia.tf32.matmul.policy.001", "api_symbols": ["torch.backends.cuda.matmul.allow_tf32", "torch.backends.cudnn.allow_tf32", "torch.cuda.get_arch_list", "torch.cuda.get_device_capability", "torch.cuda.get_device_properties"], "source_url": "https://blogs.nvidia.com/blog/tensorfloat-32-precision-format/"}');
